# Copy this file to .env and fill in the API key. The real .env is git-ignored.
GEMINI_API_KEY=
SORCERER_PROVIDER=gemini
SORCERER_HOST=https://generativelanguage.googleapis.com/v1beta
SORCERER_MODEL=gemini-3.5-flash
SORCERER_EFFORT=medium

# Provider-backed background prose is optional and disabled by default to avoid surprise spend.
SORCERER_BACKGROUND_ENABLED=false
